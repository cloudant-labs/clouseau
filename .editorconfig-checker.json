{
  "Version": "v3.6.1",
  "Verbose": false,
  "Debug": false,
  "IgnoreDefaults": false,
  "SpacesAfterTabs": false,
  "NoColor": false,
  "Exclude": [
    "LICENSE",
    "^actors/*",
    "^artifacts/*",
    "^ci-artifacts/*",
    "^clouseau-ctrl/src/clouseau_ctrl.erl",
    "^clouseau/src/main/scala/com/cloudant/ziose/clouseau/ClouseauQueryParser.scala",
    "^clouseau/src/main/scala/com/cloudant/ziose/clouseau/ClouseauTypeFactorySpec.scala",
    "^clouseau/src/main/scala/com/cloudant/ziose/clouseau/DistanceValueSource.scala",
    "^clouseau/src/main/scala/com/cloudant/ziose/clouseau/ExternalSnapshotDeletionPolicy.scala",
    "^clouseau/src/main/scala/com/cloudant/ziose/clouseau/IndexService.scala",
    "^clouseau/src/main/scala/com/cloudant/ziose/clouseau/PerFieldAnalyzer.scala",
    "^clouseau/src/test/scala/com/cloudant/ziose/clouseau/ConfigSpec.scala",
    "^zeunit/test/spawn_tests.erl",
    "^experiments/*",
    "^project/project/*",
    "^project/target/*",
    "^target/*",
    "^node_modules/*",
    "TEST-*.xml",
    "^vendor/*",
    ".*.lock"
  ],
  "AllowedContentTypes": [],
  "PassedFiles": [],
  "Disable": {
    "EndOfLine": false,
    "Indentation": false,
    "InsertFinalNewline": true,
    "TrimTrailingWhitespace": false,
    "IndentSize": false,
    "MaxLineLength": false
  }
}
